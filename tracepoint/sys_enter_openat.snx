map execve_counter {
    type: .hash;
    key: u32;
    value: u64;
    max: 10240;
}

unit trace_execve {
    section: "tracepoint/syscalls/sys_enter_execve";
    license: "GPL";
    
    reg pid_tgid = get_pid_tgid();
    reg pid = pid_tgid;
    
    heap count_ptr = execve_counter.lookup(pid);

    if guard(count_ptr) {
        *count_ptr += 1;
    } else {
        execve_counter.update(pid, 1);
    }

    return 0;
}